<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UltrasoundAssistant.DoctorClient.ViewModels.MainMenu"
             x:Class="UltrasoundAssistant.DoctorClient.Views.MainMenu.RegistrarDashboardView"
             x:DataType="vm:RegistrarDashboardViewModel">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <DockPanel Margin="10" Grid.Row="0">
      <TextBlock Text="Панель регистратора"
                 FontSize="20"
                 FontWeight="Bold"
                 VerticalAlignment="Center"
                 DockPanel.Dock="Left"/>

      <Button Content="⎋ Выйти"
              Command="{Binding LogoutCommand}"
              HorizontalAlignment="Right"
              Background="#e74c3c"
              Foreground="White"
              Padding="10,5"
              FontWeight="Bold"
              BorderThickness="0"
              CornerRadius="5"
              DockPanel.Dock="Right"/>
    </DockPanel>

    <StackPanel Grid.Row="1" Margin="20" Spacing="10">
      <Button Content="Список пациентов" Command="{Binding OpenPatientsCommand}" />
    </StackPanel>
  </Grid>
</UserControl>