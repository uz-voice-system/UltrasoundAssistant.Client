<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UltrasoundAssistant.DoctorClient.ViewModels.Appointment"
             x:Class="UltrasoundAssistant.DoctorClient.Views.Appointment.AppointmentRegistrationView"
             x:DataType="vm:AppointmentRegistrationViewModel"
             x:Name="Root">

  <Grid Margin="14" RowDefinitions="Auto,*,Auto" ColumnDefinitions="2*,3*">

    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,10">

      <DockPanel>
        <Button Content="← Назад"
                Command="{Binding GoBackCommand}"
                DockPanel.Dock="Left"/>

        <TextBlock Text="Записать пациента на приём"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
      </DockPanel>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,10,0">

      <ScrollViewer>
        <StackPanel Spacing="12">

          <TextBlock Text="Новая запись"
                     FontSize="18"
                     FontWeight="Bold"/>

          <TextBlock Text="Пациент"/>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBox Width="260"
                     Watermark="Поиск пациента"
                     Text="{Binding PatientSearchText, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Найти"
                    Command="{Binding SearchPatientsCommand}" />
          </StackPanel>

          <ComboBox ItemsSource="{Binding Patients}"
                    SelectedItem="{Binding SelectedPatient}"
                    PlaceholderText="Выберите пациента">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <StackPanel>
                  <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding PhoneNumber}" Foreground="#777" FontSize="12"/>
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Text="Врач"/>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBox Width="260"
                     Watermark="Поиск врача"
                     Text="{Binding DoctorSearchText, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Найти"
                    Command="{Binding SearchDoctorsCommand}" />
          </StackPanel>

          <ComboBox ItemsSource="{Binding Doctors}"
                    SelectedItem="{Binding SelectedDoctor}"
                    PlaceholderText="Выберите врача">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <StackPanel>
                  <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"/>
                  <TextBlock Foreground="#777" FontSize="12">
                    <Run Text="{Binding Specialization}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding Cabinet}"/>
                  </TextBlock>
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Text="Шаблон исследования"/>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBox Width="260"
                     Watermark="Поиск шаблона"
                     Text="{Binding TemplateSearchText, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Найти"
                    Command="{Binding SearchTemplatesCommand}" />
          </StackPanel>

          <ComboBox ItemsSource="{Binding Templates}"
                    SelectedItem="{Binding SelectedTemplate}"
                    PlaceholderText="Выберите шаблон">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <StackPanel>
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding DefaultAppointmentDurationMinutes, StringFormat='Длительность: {0} мин.'}"
                             Foreground="#777"
                             FontSize="12"/>
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
            <StackPanel Grid.Column="0">
              <TextBlock Text="Дата"/>
              <DatePicker SelectedDate="{Binding AppointmentDate}" />
            </StackPanel>

            <StackPanel Grid.Column="1">
              <TextBlock Text="Время"/>
              <TimePicker SelectedTime="{Binding AppointmentTime}" />
            </StackPanel>
          </Grid>

          <TextBlock Text="Длительность, минут"/>
          <NumericUpDown Minimum="5"
                         Maximum="240"
                         Increment="5"
                         Value="{Binding DurationMinutes}" />

          <TextBlock Text="Комментарий"/>
          <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                   AcceptsReturn="True"
                   MinHeight="70"
                   Watermark="Комментарий к записи, если нужен"/>

          <Button Content="Создать запись и отчёт-черновик"
                  Command="{Binding CreateAppointmentCommand}"
                  Padding="14,8"
                  HorizontalAlignment="Stretch"/>

          <TextBlock Text="{Binding ErrorMessage}"
                     Foreground="Red"
                     TextWrapping="Wrap"/>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="1"
          Grid.Column="1"
          RowDefinitions="Auto,*">

      <Border Grid.Row="0"
              Background="#F7F8FA"
              BorderBrush="#DDDDDD"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12"
              Margin="0,0,0,10">

        <StackPanel Spacing="10">
          <TextBlock Text="Существующие записи"
                     FontSize="18"
                     FontWeight="Bold"/>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox Width="260"
                     Watermark="Поиск по пациенту, врачу или шаблону"
                     Text="{Binding AppointmentSearchText, UpdateSourceTrigger=PropertyChanged}" />

            <DatePicker SelectedDate="{Binding FilterFromDate}" />
            <DatePicker SelectedDate="{Binding FilterToDate}" />

            <Button Content="Найти"
                    Command="{Binding SearchAppointmentsCommand}" />

            <Button Content="Сбросить"
                    Command="{Binding ClearAppointmentFiltersCommand}" />
          </StackPanel>

          <Expander Header="Дополнительные параметры"
                    IsExpanded="{Binding AreAdditionalFiltersVisible}">
            <Grid ColumnDefinitions="*,*,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="10"
                  RowSpacing="8"
                  Margin="0,10,0,0">

              <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock Text="Статус"/>
                <ComboBox ItemsSource="{Binding Statuses}"
                          SelectedItem="{Binding FilterStatus}" />
              </StackPanel>

              <StackPanel Grid.Row="0" Grid.Column="1">
                <TextBlock Text="Врач"/>
                <ComboBox ItemsSource="{Binding Doctors}"
                          SelectedItem="{Binding SelectedDoctor}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding FullName}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <StackPanel Grid.Row="0" Grid.Column="2">
                <TextBlock Text="Шаблон"/>
                <ComboBox ItemsSource="{Binding Templates}"
                          SelectedItem="{Binding SelectedTemplate}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <CheckBox Grid.Row="1"
                        Grid.Column="0"
                        Content="Показывать удалённые"
                        IsChecked="{Binding IncludeDeleted}" />

            </Grid>
          </Expander>
        </StackPanel>
      </Border>

      <DataGrid Grid.Row="1"
                ItemsSource="{Binding Appointments}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="Horizontal"
                BorderBrush="#DDDDDD"
                BorderThickness="1">

        <DataGrid.Columns>
          <DataGridTextColumn Header="Пациент"
                              Binding="{Binding PatientFullName}"
                              Width="2*" />

          <DataGridTextColumn Header="Врач"
                              Binding="{Binding DoctorFullName}"
                              Width="2*" />

          <DataGridTextColumn Header="Шаблон"
                              Binding="{Binding TemplateName}"
                              Width="2*" />

          <DataGridTextColumn Header="Начало"
                              Binding="{Binding StartAtUtc, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                              Width="160" />

          <DataGridTextColumn Header="Окончание"
                              Binding="{Binding EndAtUtc, StringFormat='{}{0:HH:mm}'}"
                              Width="100" />

          <DataGridTextColumn Header="Статус"
                              Binding="{Binding Status}"
                              Width="120" />
        </DataGrid.Columns>
      </DataGrid>

    </Grid>

  </Grid>
</UserControl>
