<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UltrasoundAssistant.DoctorClient.ViewModels.MainMenu"
             x:Class="UltrasoundAssistant.DoctorClient.Views.MainMenu.DoctorDashboardView"
             x:DataType="vm:DoctorDashboardViewModel"
             x:Name="Root"
             AttachedToVisualTree="UserControl_OnAttachedToVisualTree">

  <Grid RowDefinitions="Auto,Auto,*,Auto"
        Margin="14">

    <!-- Заголовок -->
    <Border Grid.Row="0"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,0,10">

      <DockPanel>
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="Панель врача"
                     FontSize="22"
                     FontWeight="Bold"/>

          <TextBlock Text="Записи на приём и работа с отчётами"
                     Foreground="#666"
                     Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Right">

          <Button Content="Архив отчётов"
                  Command="{Binding OpenReportsArchiveCommand}"
                  Padding="14,7"/>

          <Button Content="⎋ Выйти"
                  Command="{Binding LogoutCommand}"
                  Background="#E74C3C"
                  Foreground="White"
                  Padding="14,7"
                  FontWeight="Bold"
                  BorderThickness="0"
                  CornerRadius="6"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Фильтры -->
    <Border Grid.Row="1"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,10">

      <StackPanel Spacing="10">

        <Grid ColumnDefinitions="320,300,300,Auto,Auto,Auto"
              ColumnSpacing="8">

          <TextBox Grid.Column="0"
                   Watermark="Поиск по пациенту или шаблону"
                   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                   VerticalAlignment="Bottom"/>

          <StackPanel Grid.Column="1"
                      Spacing="4">
            <TextBlock Text="Дата с"
                       Foreground="#666"/>

            <DatePicker SelectedDate="{Binding FilterFromDate}"
                        Width="300"/>
          </StackPanel>

          <StackPanel Grid.Column="2"
                      Spacing="4">
            <TextBlock Text="Дата по"
                       Foreground="#666"/>

            <DatePicker SelectedDate="{Binding FilterToDate}"
                        Width="300"/>
          </StackPanel>

          <Button Grid.Column="3"
                  Content="Найти"
                  Command="{Binding SearchAppointmentsCommand}"
                  Padding="14,7"
                  VerticalAlignment="Bottom"/>

          <Button Grid.Column="4"
                  Content="Сегодня"
                  Command="{Binding LoadTodayAppointmentsCommand}"
                  Padding="14,7"
                  VerticalAlignment="Bottom"/>

          <Button Grid.Column="5"
                  Content="Сбросить"
                  Command="{Binding ClearFiltersCommand}"
                  Padding="14,7"
                  VerticalAlignment="Bottom"/>
        </Grid>

        <Expander Header="Дополнительные параметры"
                  IsExpanded="{Binding AreAdditionalFiltersVisible}">

          <Grid ColumnDefinitions="260,260,*"
                ColumnSpacing="10"
                Margin="0,10,0,0">

            <StackPanel Grid.Column="0"
                        Spacing="4">
              <TextBlock Text="Статус записи"
                         Foreground="#666"/>

              <ComboBox ItemsSource="{Binding StatusOptions}"
                        SelectedItem="{Binding SelectedStatusText}"
                        Width="260"/>
            </StackPanel>

            <CheckBox Grid.Column="1"
                      Content="Показывать удалённые"
                      IsChecked="{Binding IncludeDeleted}"
                      VerticalAlignment="Bottom"/>
          </Grid>
        </Expander>
      </StackPanel>
    </Border>

    <!-- Карточки записей -->
    <ScrollViewer Grid.Row="2"
                  VerticalScrollBarVisibility="Auto">

      <ItemsControl ItemsSource="{Binding TodayAppointments}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:DoctorAppointmentCardItem">

            <Border Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,0,10">

              <Grid ColumnDefinitions="150,*,220,Auto"
                    ColumnSpacing="14">

                <!-- Время -->
                <StackPanel Grid.Column="0"
                            Spacing="5">

                  <TextBlock Text="{Binding DateText}"
                             Foreground="#666"
                             FontSize="13"/>

                  <TextBlock Text="{Binding TimeText}"
                             FontSize="22"
                             FontWeight="Bold"
                             TextWrapping="NoWrap"/>

                  <Border Background="{Binding StatusBackground}"
                          CornerRadius="10"
                          Padding="9,4"
                          HorizontalAlignment="Left">

                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{Binding StatusForeground}"
                               FontWeight="Bold"
                               FontSize="13"/>
                  </Border>
                </StackPanel>

                <!-- Основная информация -->
                <StackPanel Grid.Column="1"
                            Spacing="6">

                  <TextBlock Text="{Binding PatientFullName}"
                             FontSize="18"
                             FontWeight="Bold"
                             TextWrapping="Wrap"/>

                  <TextBlock Text="{Binding TemplateName}"
                             Foreground="#555"
                             TextWrapping="Wrap"/>

                  <TextBlock Text="{Binding ReportText}"
                             Foreground="#777"
                             FontSize="13"/>
                </StackPanel>

                <!-- Дополнительно -->
                <StackPanel Grid.Column="2"
                            Spacing="4">

                  <TextBlock Text="Врач"
                             Foreground="#777"
                             FontSize="12"/>

                  <TextBlock Text="{Binding DoctorFullName}"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Действия -->
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">

                  <Button Content="Заполнить отчёт"
                          Command="{Binding #Root.DataContext.OpenReportCommand}"
                          CommandParameter="{Binding}"
                          IsEnabled="{Binding CanOpenReport}"
                          Padding="12,7"/>

                  <Button Content="Не явился"
                          Background="#F39C12"
                          Foreground="White"
                          Command="{Binding #Root.DataContext.MarkNoShowCommand}"
                          CommandParameter="{Binding}"
                          IsEnabled="{Binding CanMarkNoShow}"
                          Padding="12,7"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Нижняя панель -->
    <Border Grid.Row="3"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,10,0,0">

      <StackPanel Orientation="Horizontal"
                  Spacing="12">

        <TextBlock Text="{Binding SuccessMessage}"
                   Foreground="Green"
                   VerticalAlignment="Center"/>

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
