<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UltrasoundAssistant.DoctorClient.ViewModels.MainMenu"
             x:Class="UltrasoundAssistant.DoctorClient.Views.MainMenu.DoctorDashboardView"
             x:DataType="vm:DoctorDashboardViewModel"
             x:Name="Root"
             AttachedToVisualTree="UserControl_OnAttachedToVisualTree">

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="14">

    <Border Grid.Row="0"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,0,10">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="Панель врача"
                     FontSize="22"
                     FontWeight="Bold"/>
          <TextBlock Text="Записи на сегодня и работа с отчётами"
                     Foreground="#666"
                     Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Right">
          <Button Content="Архив отчётов"
                  Command="{Binding OpenReportsArchiveCommand}"
                  Padding="14,7"/>

          <Button Content="⎋ Выйти"
                  Command="{Binding LogoutCommand}"
                  Background="#E74C3C"
                  Foreground="White"
                  Padding="14,7"
                  FontWeight="Bold"
                  BorderThickness="0"
                  CornerRadius="6"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,10">

      <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox Width="320"
                   Watermark="Поиск по пациенту, врачу или шаблону"
                   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

          <DatePicker SelectedDate="{Binding FilterFromDate}" />
          <DatePicker SelectedDate="{Binding FilterToDate}" />

          <Button Content="Найти"
                  Command="{Binding SearchAppointmentsCommand}" />

          <Button Content="Сегодня"
                  Command="{Binding LoadTodayAppointmentsCommand}" />

          <Button Content="Сбросить"
                  Command="{Binding ClearFiltersCommand}" />
        </StackPanel>

        <Expander Header="Дополнительные параметры"
                  IsExpanded="{Binding AreAdditionalFiltersVisible}">
          <Grid ColumnDefinitions="240,240,*"
                ColumnSpacing="10"
                Margin="0,10,0,0">

            <StackPanel Grid.Column="0">
              <TextBlock Text="Статус записи"/>
              <ComboBox ItemsSource="{Binding Statuses}"
                        SelectedItem="{Binding SelectedStatus}" />
            </StackPanel>

            <CheckBox Grid.Column="1"
                      Content="Показывать удалённые"
                      IsChecked="{Binding IncludeDeleted}"
                      VerticalAlignment="Bottom" />

          </Grid>
        </Expander>
      </StackPanel>
    </Border>

    <DataGrid Grid.Row="2"
              ItemsSource="{Binding TodayAppointments}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              GridLinesVisibility="Horizontal"
              BorderBrush="#DDDDDD"
              BorderThickness="1">

      <DataGrid.Columns>
        <DataGridTextColumn Header="Начало"
                            Binding="{Binding StartAtUtc, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                            Width="160" />

        <DataGridTextColumn Header="Окончание"
                            Binding="{Binding EndAtUtc, StringFormat='{}{0:HH:mm}'}"
                            Width="100" />

        <DataGridTextColumn Header="Пациент"
                            Binding="{Binding PatientFullName}"
                            Width="2*" />

        <DataGridTextColumn Header="Шаблон"
                            Binding="{Binding TemplateName}"
                            Width="2*" />

        <DataGridTextColumn Header="Статус"
                            Binding="{Binding Status}"
                            Width="130" />

        <DataGridTemplateColumn Header="Действия" Width="360">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="Заполнить отчёт"
                        Command="{Binding DataContext.OpenReportCommand, ElementName=Root}"
                        CommandParameter="{Binding}" />

                <Button Content="Не явился"
                        Background="#F39C12"
                        Foreground="White"
                        Command="{Binding DataContext.MarkNoShowCommand, ElementName=Root}"
                        CommandParameter="{Binding}" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>

    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                Spacing="12"
                Margin="0,10,0,0">

      <TextBlock Text="{Binding SuccessMessage}"
                 Foreground="Green"
                 VerticalAlignment="Center"/>

      <TextBlock Text="{Binding ErrorMessage}"
                 Foreground="Red"
                 VerticalAlignment="Center"/>
    </StackPanel>

  </Grid>
</UserControl>
