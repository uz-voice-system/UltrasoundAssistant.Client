<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UltrasoundAssistant.DoctorClient.ViewModels.Report"
             xmlns:templateDto="using:UltrasoundAssistant.DoctorClient.Models.Reads.Templates.Search"
             x:Class="UltrasoundAssistant.DoctorClient.Views.Report.DoctorReportsArchiveView"
             x:DataType="vm:DoctorReportsArchiveViewModel"
             x:Name="Root"
             AttachedToVisualTree="UserControl_OnAttachedToVisualTree">

  <Grid Margin="14"
        RowDefinitions="Auto,*,Auto"
        ColumnDefinitions="3*,2*">

    <Border Grid.Row="0"
            Grid.Column="0"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,10,10">

      <StackPanel Spacing="10">

        <DockPanel>
          <Button Content="← Назад"
                  Command="{Binding GoBackCommand}"
                  DockPanel.Dock="Left"/>

          <StackPanel Margin="12,0,0,0">
            <TextBlock Text="Архив отчётов"
                       FontSize="20"
                       FontWeight="Bold"/>

            <TextBlock Text="Просмотр, редактирование доступных отчётов, печать и архивирование"
                       Foreground="#666"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </DockPanel>

        <StackPanel Orientation="Horizontal"
                    Spacing="8">

          <TextBox Width="280"
                   Watermark="Поиск по пациенту или шаблону"
                   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

          <DatePicker Width="300"
                      SelectedDate="{Binding CreatedFromDate}"/>

          <DatePicker Width="300"
                      SelectedDate="{Binding CreatedToDate}"/>

          <ComboBox Width="190"
                    ItemsSource="{Binding StatusOptions}"
                    SelectedItem="{Binding SelectedStatusText}"/>
        </StackPanel>

        <DockPanel LastChildFill="True">

          <StackPanel DockPanel.Dock="Right"
                      Orientation="Horizontal"
                      Spacing="8"
                      Margin="10,0,0,0">

            <Button Content="Найти"
                    Command="{Binding FilterReportsCommand}"
                    Padding="14,7"/>

            <Button Content="Сбросить"
                    Command="{Binding ClearFiltersCommand}"
                    Padding="14,7"/>
          </StackPanel>

          <Expander Header="Дополнительные параметры"
                    IsExpanded="{Binding AreAdditionalFiltersVisible}">

            <Grid ColumnDefinitions="320,220,*"
                  ColumnSpacing="10"
                  Margin="0,10,0,0">

              <StackPanel Grid.Column="0">
                <TextBlock Text="Шаблон"/>
                <ComboBox ItemsSource="{Binding Templates}"
                          SelectedItem="{Binding SelectedTemplate}"
                          HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="templateDto:TemplateSummaryDto">
                      <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <CheckBox Grid.Column="1"
                        Content="Показывать удалённые"
                        IsChecked="{Binding IncludeDeleted}"
                        VerticalAlignment="Bottom"/>
            </Grid>
          </Expander>

        </DockPanel>

      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,0,10,0">

      <Grid RowDefinitions="Auto,*" RowSpacing="10">

        <DockPanel Grid.Row="0">
          <TextBlock Text="Найденные отчёты"
                     FontSize="18"
                     FontWeight="Bold"
                     DockPanel.Dock="Left"/>

          <ProgressBar Width="160"
                       Height="14"
                       IsIndeterminate="True"
                       IsVisible="{Binding IsBusy}"
                       DockPanel.Dock="Right"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

          <ItemsControl ItemsSource="{Binding Reports}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:DoctorReportArchiveListItem" x:CompileBindings="False">

                <Border Background="{Binding CardBackground}"
                        BorderBrush="{Binding CardBorderBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="14"
                        Margin="0,0,0,10">

                  <Grid RowDefinitions="Auto,Auto,Auto"
                        RowSpacing="10">

                    <DockPanel Grid.Row="0">
                      <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{Binding PatientFullName}"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="{Binding TemplateName}"
                                   Foreground="#666"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0"/>
                      </StackPanel>

                      <Border Background="{Binding StatusBackground}"
                              CornerRadius="12"
                              Padding="10,4"
                              DockPanel.Dock="Right">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{Binding StatusForeground}"
                                   FontWeight="Bold"/>
                      </Border>
                    </DockPanel>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,*,*"
                          ColumnSpacing="10">

                      <Border Grid.Column="0"
                              Background="#F7F8FA"
                              CornerRadius="8"
                              Padding="8">
                        <StackPanel>
                          <TextBlock Text="Дата приёма"
                                     Foreground="#666"
                                     FontSize="12"/>
                          <TextBlock Text="{Binding AppointmentTimeText}"
                                     FontWeight="Bold"/>
                        </StackPanel>
                      </Border>

                      <Border Grid.Column="1"
                              Background="#F7F8FA"
                              CornerRadius="8"
                              Padding="8">
                        <StackPanel>
                          <TextBlock Text="Дата создания отчёта"
                                     Foreground="#666"
                                     FontSize="12"/>
                          <TextBlock Text="{Binding CreatedAtText}"
                                     FontWeight="Bold"/>
                        </StackPanel>
                      </Border>

                      <Border Grid.Column="2"
                              Background="#F7F8FA"
                              CornerRadius="8"
                              Padding="8">
                        <StackPanel>
                          <TextBlock Text="Статус"
                                     Foreground="#666"
                                     FontSize="12"/>
                          <TextBlock Text="{Binding StatusText}"
                                     FontWeight="Bold"/>
                        </StackPanel>
                      </Border>
                    </Grid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">

                      <Button Content="Просмотр"
                              Command="{Binding DataContext.PreviewReportCommand, ElementName=Root}"
                              CommandParameter="{Binding}"
                              Padding="12,6"/>

                      <Button Content="Редактировать"
                              IsVisible="{Binding CanEdit}"
                              Command="{Binding DataContext.EditReportCommand, ElementName=Root}"
                              CommandParameter="{Binding}"
                              Padding="12,6"/>

                      <Button Content="Печать"
                              IsVisible="{Binding CanPrint}"
                              Command="{Binding DataContext.GeneratePdfCommand, ElementName=Root}"
                              CommandParameter="{Binding}"
                              Padding="12,6"/>

                      <Button Content="Архивировать"
                              IsVisible="{Binding CanArchive}"
                              Background="#2457A6"
                              Foreground="White"
                              Command="{Binding DataContext.ArchiveReportCommand, ElementName=Root}"
                              CommandParameter="{Binding}"
                              Padding="12,6"/>
                    </StackPanel>

                  </Grid>
                </Border>

              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2"
                Grid.Column="0"
                Orientation="Horizontal"
                Spacing="12"
                Margin="0,10,10,0">

      <TextBlock Text="{Binding SuccessMessage}"
                 Foreground="Green"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap"/>

      <TextBlock Text="{Binding ErrorMessage}"
                 Foreground="Red"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap"/>
    </StackPanel>

    <Border Grid.Row="0"
            Grid.RowSpan="3"
            Grid.Column="1"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            IsVisible="{Binding IsDetailsPanelVisible}">

      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">

          <DockPanel>
            <TextBlock Text="Предпросмотр отчёта"
                       FontWeight="Bold"
                       FontSize="18"
                       DockPanel.Dock="Left"/>

            <Button Content="Закрыть"
                    DockPanel.Dock="Right"
                    Command="{Binding CloseDetailsCommand}"/>
          </DockPanel>

          <Border Background="#FFFFFF"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10">

            <StackPanel Spacing="8">

              <TextBlock Text="Основная информация"
                         FontWeight="Bold"
                         FontSize="15"/>

              <Grid ColumnDefinitions="Auto,*"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                    ColumnSpacing="10"
                    RowSpacing="6">

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Пациент:"
                           Foreground="#666"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding SelectedReport.PatientFullName}"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Врач:"
                           Foreground="#666"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding SelectedReport.DoctorFullName}"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Шаблон:"
                           Foreground="#666"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding SelectedReport.TemplateName}"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Text="Время:"
                           Foreground="#666"/>
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Text="{Binding SelectedReportAppointmentTimeText}"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="Статус:"
                           Foreground="#666"/>
                <Border Grid.Row="4"
                        Grid.Column="1"
                        Background="#EEF2F7"
                        CornerRadius="10"
                        Padding="8,3"
                        HorizontalAlignment="Left">
                  <TextBlock Text="{Binding SelectedReportStatusText}"
                             FontWeight="Bold"/>
                </Border>
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="#FFFFFF"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10">

            <StackPanel Spacing="8">
              <TextBlock Text="Изображение УЗИ"
                         FontWeight="Bold"
                         FontSize="15"/>

              <TextBlock Text="{Binding SelectedReportImageText}"
                         Foreground="#666"
                         TextWrapping="Wrap"/>

              <Border Background="#F7F8FA"
                      BorderBrush="#DDDDDD"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="8"
                      IsVisible="{Binding HasSelectedReportImage}">

                <Image Source="{Binding SelectedReportImage}"
                       Stretch="Uniform"
                       MaxHeight="280"/>
              </Border>
            </StackPanel>
          </Border>

          <Border Background="#FFFFFF"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10">

            <StackPanel Spacing="8">
              <TextBlock Text="Содержимое отчёта"
                         FontWeight="Bold"
                         FontSize="15"/>

              <TextBox Text="{Binding SelectedReportContentText}"
                       AcceptsReturn="True"
                       IsReadOnly="True"
                       TextWrapping="Wrap"
                       MinHeight="360"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Border>

  </Grid>
</UserControl>
