<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:reportVm="using:UltrasoundAssistant.DoctorClient.ViewModels.Report"
             x:Class="UltrasoundAssistant.DoctorClient.Views.Report.ReportEditorView"
             x:DataType="reportVm:ReportEditorViewModel"
             x:Name="Root">

  <Grid Margin="14"
        RowDefinitions="Auto,Auto,*,Auto"
        ColumnDefinitions="3*,2*">

    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,10">

      <DockPanel>
        <Button Content="← Назад"
                Command="{Binding GoBackCommand}"
                DockPanel.Dock="Left"
                Padding="12,6"/>

        <StackPanel Margin="12,0,0,0">
          <TextBlock Text="Заполнение отчёта УЗИ"
                     FontSize="20"
                     FontWeight="Bold"/>

          <TextBlock Text="{Binding StatusText, StringFormat='Статус: {0}'}"
                     Foreground="#666"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,10,10">

      <Grid ColumnDefinitions="*,*,*"
            ColumnSpacing="10">

        <StackPanel Grid.Column="0">
          <TextBlock Text="Пациент"/>
          <TextBox Text="{Binding PatientName}"
                   IsReadOnly="True"/>
        </StackPanel>

        <StackPanel Grid.Column="1">
          <TextBlock Text="Шаблон"/>
          <TextBox Text="{Binding TemplateName}"
                   IsReadOnly="True"/>
        </StackPanel>

        <StackPanel Grid.Column="2">
          <TextBlock Text="Время приёма"/>
          <TextBox Text="{Binding AppointmentTimeText}"
                   IsReadOnly="True"/>
        </StackPanel>

      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="1"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,10">

      <StackPanel Spacing="8">
        <TextBlock Text="Голосовой ввод"
                   FontSize="18"
                   FontWeight="Bold"/>

        <TextBlock Text="Во время записи врач может произнести «пауза» или «продолжить», если нужно временно остановить или возобновить диктовку."
                   TextWrapping="Wrap"
                   Foreground="#666"/>

        <StackPanel Orientation="Horizontal"
                    Spacing="8">

          <Button Content="Начать запись"
                  Command="{Binding StartRecordingCommand}"
                  IsEnabled="{Binding CanStartRecording}"
                  Padding="12,6"/>

          <Button Content="Закончить запись"
                  Command="{Binding StopRecordingCommand}"
                  IsEnabled="{Binding CanStopRecording}"
                  Padding="12,6"/>

        </StackPanel>
      </StackPanel>
    </Border>

    <Border Grid.Row="2"
            Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,0,10,10">

      <Grid RowDefinitions="Auto,*"
            RowSpacing="10">

        <TextBlock Grid.Row="0"
                   Text="Поля отчёта"
                   FontSize="18"
                   FontWeight="Bold"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

          <ItemsControl ItemsSource="{Binding ReportBlocks}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="reportVm:ReportBlockEditorItem">

                <Border Background="#F7F8FA"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,12">

                  <StackPanel Spacing="10">

                    <StackPanel>
                      <TextBlock Text="{Binding BlockName}"
                                 FontSize="17"
                                 FontWeight="Bold"/>

                      <Border Background="#FFF8E1"
                              BorderBrush="#F2C94C"
                              BorderThickness="1"
                              CornerRadius="6"
                              Padding="8"
                              Margin="0,6,0,0">

                        <StackPanel>
                          <TextBlock Text="Фразы блока, которые можно произнести:"
                                     FontWeight="Bold"
                                     Foreground="#7A5B00"/>

                          <TextBlock Text="{Binding BlockPhrasesText}"
                                     Foreground="#7A5B00"
                                     TextWrapping="Wrap"
                                     Margin="0,3,0,0"/>
                        </StackPanel>
                      </Border>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Fields}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="reportVm:ReportFieldEditorItem">

                          <Border Background="{Binding RecognitionBackground}"
                                  BorderBrush="{Binding RecognitionBorderBrush}"
                                  BorderThickness="2"
                                  CornerRadius="8"
                                  Padding="10"
                                  Margin="18,0,0,8">

                            <Grid ColumnDefinitions="2*,3*,1.5*"
                                  RowDefinitions="Auto,Auto,Auto"
                                  ColumnSpacing="10"
                                  RowSpacing="8">

                              <StackPanel Grid.Row="0"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="3">

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                  <TextBlock Text="{Binding DisplayName}"
                                             FontWeight="Bold"
                                             FontSize="15"
                                             TextWrapping="Wrap"/>

                                  <Border Background="#E8F1FF"
                                          CornerRadius="10"
                                          Padding="8,3"
                                          IsVisible="{Binding HasRoleText}">
                                    <TextBlock Text="{Binding RoleText}"
                                               Foreground="#2457A6"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                  </Border>

                                    <Border Background="#FFFFFF"
                                          BorderBrush="{Binding RecognitionBorderBrush}"
                                          BorderThickness="1"
                                          CornerRadius="10"
                                          Padding="8,3"
                                          IsVisible="{Binding HasRecognitionInfo}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                      <TextBlock Text="{Binding RecognitionText}"
                                                 Foreground="{Binding RecognitionForeground}"
                                                 FontSize="12"
                                                 FontWeight="Bold"/>

                                      <TextBlock Text="{Binding ConfidenceText}"
                                                 Foreground="{Binding RecognitionForeground}"
                                                 FontSize="12"/>
                                    </StackPanel>
                                  </Border>
                                </StackPanel>
                              </StackPanel>

                              <Border Grid.Row="1"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="3"
                                      Background="#F3F6FA"
                                      BorderBrush="#DCE3EA"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="8">

                                <StackPanel>
                                  <TextBlock Text="Фразы поля, которые можно произнести:"
                                             FontWeight="Bold"
                                             Foreground="#555"/>

                                  <TextBlock Text="{Binding PhrasesText}"
                                             Foreground="#555"
                                             TextWrapping="Wrap"
                                             Margin="0,3,0,0"/>
                                </StackPanel>
                              </Border>

                              <StackPanel Grid.Row="2"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2">
                                <TextBlock Text="Значение"
                                           FontWeight="Bold"
                                           Foreground="#555"/>

                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="{Binding IsLongTextField}"
                                         TextWrapping="Wrap"
                                         MinHeight="{Binding EditorMinHeight}"
                                         VerticalContentAlignment="Top"
                                         IsReadOnly="{Binding #Root.DataContext.IsCompletedOrArchived}"/>
                              </StackPanel>

                              <StackPanel Grid.Row="2"
                                          Grid.Column="2">
                                <TextBlock Text="Норма / проверка"
                                           FontWeight="Bold"
                                           Foreground="#555"/>

                                <Border Background="#F7F8FA"
                                        BorderBrush="#DDDDDD"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8"
                                        MinHeight="42">

                                  <TextBlock Text="{Binding NormMessage}"
                                             Foreground="#666"
                                             TextWrapping="Wrap"/>
                                </Border>
                              </StackPanel>

                            </Grid>
                          </Border>

                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                  </StackPanel>
                </Border>

              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="2"
                  Grid.Column="1"
                  VerticalScrollBarVisibility="Auto">

      <StackPanel Spacing="10">

        <Border Background="#F7F8FA"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">

          <StackPanel Spacing="8">
            <TextBlock Text="Изображение УЗИ"
                       FontSize="18"
                       FontWeight="Bold"/>

            <TextBlock Text="{Binding UltrasoundImageInfoText}"
                       Foreground="#666"
                       TextWrapping="Wrap"/>

            <Border Background="#FFFFFF"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    MinHeight="180">

              <Grid>
                <TextBlock Text="Изображение не загружено"
                           Foreground="#999"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !HasUltrasoundImage}"/>

                <Image Source="{Binding UltrasoundImagePreview}"
                       Stretch="Uniform"
                       MaxHeight="260"
                       IsVisible="{Binding HasUltrasoundImage}"/>
              </Grid>
            </Border>

            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <Button Content="Загрузить / заменить"
                      Click="UploadImageButton_OnClick"
                      IsEnabled="{Binding CanUploadImage}"
                      Padding="12,6"/>

              <Button Content="Удалить изображение"
                      Command="{Binding DeleteImageCommand}"
                      IsEnabled="{Binding CanDeleteImage}"
                      Background="#E74C3C"
                      Foreground="White"
                      Padding="12,6"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Background="#F7F8FA"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">

          <Grid RowDefinitions="Auto,160,Auto,220"
                RowSpacing="8">

            <TextBlock Grid.Row="0"
                       Text="Результат распознавания"
                       FontSize="18"
                       FontWeight="Bold"/>

            <TextBox Grid.Row="1"
                     Text="{Binding RecognizedText}"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"/>

            <TextBlock Grid.Row="2"
                       Text="Не сопоставлено / требует проверки"
                       FontWeight="Bold"/>

            <TextBox Grid.Row="3"
                     Text="{Binding UnmatchedRecognitions}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"/>
          </Grid>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="3"
            Grid.ColumnSpan="2"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">

      <DockPanel>
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="{Binding SuccessMessage}"
                     Foreground="Green"/>
          <TextBlock Text="{Binding ErrorMessage}"
                     Foreground="Red"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10">

          <Button Content="Сохранить отчёт"
                  Command="{Binding SaveReportCommand}"
                  IsEnabled="{Binding CanSave}"
                  Padding="14,7"/>

          <Button Content="Завершить отчёт"
                  Command="{Binding CompleteReportCommand}"
                  IsEnabled="{Binding CanComplete}"
                  Padding="14,7"/>

          <Button Content="Распечатать отчёт"
                  Command="{Binding GeneratePdfCommand}"
                  IsEnabled="{Binding CanGeneratePdf}"
                  Padding="14,7"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.RowSpan="4"
            Grid.ColumnSpan="2"
            Background="#80000000"
            IsVisible="{Binding IsRecognizing}"
            ZIndex="1000">

      <Grid>
        <Border Width="340"
                Padding="22"
                CornerRadius="12"
                Background="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

          <StackPanel Spacing="12">
            <TextBlock Text="Идёт распознавание..."
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Пожалуйста, дождитесь окончания обработки аудио."
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>

            <ProgressBar IsIndeterminate="True"
                         Height="16"/>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border Grid.RowSpan="4"
            Grid.ColumnSpan="2"
            Background="#40000000"
            IsVisible="{Binding IsBusy}"
            ZIndex="900">

      <Grid>
        <ProgressBar Width="260"
                     Height="16"
                     IsIndeterminate="True"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
      </Grid>
    </Border>

  </Grid>
</UserControl>
