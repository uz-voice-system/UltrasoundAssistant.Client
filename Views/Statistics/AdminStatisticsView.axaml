<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UltrasoundAssistant.DoctorClient.ViewModels.Statistics"
             xmlns:userDto="using:UltrasoundAssistant.DoctorClient.Models.Reads.Users.Search"
             xmlns:templateDto="using:UltrasoundAssistant.DoctorClient.Models.Reads.Templates.Search"
             xmlns:stats="using:UltrasoundAssistant.DoctorClient.Models.Statistics"
             x:Class="UltrasoundAssistant.DoctorClient.Views.Statistics.AdminStatisticsView"
             x:DataType="vm:AdminStatisticsViewModel">

  <Grid Margin="14"
        RowDefinitions="Auto,Auto,*,Auto">

    <Border Grid.Row="0"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,10">

      <DockPanel>
        <Button Content="← Назад"
                Command="{Binding GoBackCommand}"
                DockPanel.Dock="Left"/>

        <StackPanel Margin="12,0,0,0">
          <TextBlock Text="Статистика администратора"
                     FontSize="20"
                     FontWeight="Bold"/>
          <TextBlock Text="Аналитика по записям, пациентам, врачам, шаблонам и отчётам"
                     Foreground="#666"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,10">

      <StackPanel Spacing="12">

        <StackPanel Orientation="Horizontal"
                    Spacing="8">

          <Button Content="Сегодня"
                  Command="{Binding SetTodayCommand}"
                  Padding="12,6"/>

          <Button Content="Последние 30 дней"
                  Command="{Binding SetLast30DaysCommand}"
                  Padding="12,6"/>

          <Button Content="Текущий месяц"
                  Command="{Binding SetCurrentMonthCommand}"
                  Padding="12,6"/>

          <Button Content="Прошлый месяц"
                  Command="{Binding SetPreviousMonthCommand}"
                  Padding="12,6"/>
        </StackPanel>

        <Grid RowDefinitions="Auto,Auto"
              RowSpacing="10">

          <Grid Grid.Row="0"
                ColumnDefinitions="180,180,*,*"
                ColumnSpacing="10">

            <StackPanel Grid.Column="0">
              <TextBlock Text="Дата с"/>
              <TextBox Text="{Binding DateFromText, UpdateSourceTrigger=PropertyChanged}"
                       Watermark="дд.мм.гггг"
                       HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
              <TextBlock Text="Дата по"/>
              <TextBox Text="{Binding DateToText, UpdateSourceTrigger=PropertyChanged}"
                       Watermark="дд.мм.гггг"
                       HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
              <TextBlock Text="Врач"/>
              <ComboBox ItemsSource="{Binding Doctors}"
                        SelectedItem="{Binding SelectedDoctor}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="userDto:UserSummaryDto">
                    <TextBlock Text="{Binding FullName}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="3">
              <TextBlock Text="Шаблон"/>
              <ComboBox ItemsSource="{Binding Templates}"
                        SelectedItem="{Binding SelectedTemplate}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="templateDto:TemplateSummaryDto">
                    <TextBlock Text="{Binding Name}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
          </Grid>

          <StackPanel Grid.Row="1"
                      Orientation="Horizontal"
                      Spacing="10"
                      HorizontalAlignment="Right">

            <Button Content="Показать"
                    Command="{Binding LoadStatisticsCommand}"
                    Padding="14,7"/>

            <Button Content="Скачать PDF"
                    Command="{Binding DownloadPdfCommand}"
                    Padding="14,7"/>

            <Button Content="Сбросить"
                    Command="{Binding ClearFiltersCommand}"
                    Padding="14,7"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="2"
                  VerticalScrollBarVisibility="Auto">

      <StackPanel Spacing="12">

        <Border Background="#FFFFFF"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">

          <StackPanel Spacing="4">
            <TextBlock Text="Период"
                       FontWeight="Bold"
                       Foreground="#666"/>
            <TextBlock Text="{Binding PeriodText}"
                       FontSize="16"/>
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,*,*,*"
              ColumnSpacing="10">

          <Border Grid.Column="0"
                  Background="#E8F1FF"
                  CornerRadius="10"
                  Padding="14">
            <StackPanel>
              <TextBlock Text="Всего записей"
                         Foreground="#2457A6"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding TotalAppointmentsCountText}"
                         FontSize="28"
                         FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="1"
                  Background="#DFF5E1"
                  CornerRadius="10"
                  Padding="14">
            <StackPanel>
              <TextBlock Text="Принято"
                         Foreground="#1E7E34"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding AcceptedAppointmentsCountText}"
                         FontSize="28"
                         FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="2"
                  Background="#F3E8FF"
                  CornerRadius="10"
                  Padding="14">
            <StackPanel>
              <TextBlock Text="Уникальных пациентов"
                         Foreground="#6F2DA8"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding UniqueAcceptedPatientsCountText}"
                         FontSize="28"
                         FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="3"
                  Background="#FFF3CD"
                  CornerRadius="10"
                  Padding="14">
            <StackPanel>
              <TextBlock Text="Отчётов"
                         Foreground="#7A5B00"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding ReportsCountText}"
                         FontSize="28"
                         FontWeight="Bold"/>
            </StackPanel>
          </Border>
        </Grid>

        <Grid ColumnDefinitions="*,*,*,*,*"
              ColumnSpacing="10">

          <Border Grid.Column="0"
                  Background="#EEF2F7"
                  CornerRadius="10"
                  Padding="14">
            <StackPanel>
              <TextBlock Text="Черновики записей"
                         Foreground="#444"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding ScheduledAppointmentsCountText}"
                         FontSize="24"
                         FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="1"
                  Background="#E8F1FF"
                  CornerRadius="10"
                  Padding="14">
            <StackPanel>
              <TextBlock Text="В процессе"
                         Foreground="#2457A6"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding InProgressAppointmentsCountText}"
                         FontSize="24"
                         FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="2"
                  Background="#DFF5E1"
                  CornerRadius="10"
                  Padding="14">
            <StackPanel>
              <TextBlock Text="Завершено"
                         Foreground="#1E7E34"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding CompletedAppointmentsCountText}"
                         FontSize="24"
                         FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="3"
                  Background="#FDE2E2"
                  CornerRadius="10"
                  Padding="14">
            <StackPanel>
              <TextBlock Text="Неявки"
                         Foreground="#B00020"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding NoShowAppointmentsCountText}"
                         FontSize="24"
                         FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="4"
                  Background="#FFF3CD"
                  CornerRadius="10"
                  Padding="14">
            <StackPanel>
              <TextBlock Text="Принято без отчёта"
                         Foreground="#7A5B00"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding AppointmentsWithoutReportCountText}"
                         FontSize="24"
                         FontWeight="Bold"/>
            </StackPanel>
          </Border>
        </Grid>

        <Grid ColumnDefinitions="*,*"
              ColumnSpacing="12">

          <Border Grid.Column="0"
                  Background="#FFFFFF"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12">

            <StackPanel Spacing="8">
              <TextBlock Text="Статистика по врачам"
                         FontSize="18"
                         FontWeight="Bold"/>

              <ScrollViewer MaxHeight="420"
                            VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding DoctorRows}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="stats:DoctorStatisticsDto">

                      <Border Background="#F7F8FA"
                              BorderBrush="#DDDDDD"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="10"
                              Margin="0,0,0,8">

                        <StackPanel Spacing="8">

                          <TextBlock Text="{Binding DoctorFullName}"
                                     FontWeight="Bold"
                                     FontSize="15"
                                     TextWrapping="Wrap"/>

                          <Grid ColumnDefinitions="*,*,*,*"
                                RowDefinitions="Auto,Auto"
                                ColumnSpacing="8"
                                RowSpacing="8">

                            <Border Grid.Row="0" Grid.Column="0" Background="#E8F1FF" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Записей" FontSize="12" Foreground="#2457A6"/>
                                <TextBlock Text="{Binding AppointmentsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Background="#DFF5E1" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Принято" FontSize="12" Foreground="#1E7E34"/>
                                <TextBlock Text="{Binding AcceptedAppointmentsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" Background="#F3E8FF" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Пациентов" FontSize="12" Foreground="#6F2DA8"/>
                                <TextBlock Text="{Binding UniqueAcceptedPatientsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="3" Background="#FFF3CD" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Отчётов" FontSize="12" Foreground="#7A5B00"/>
                                <TextBlock Text="{Binding ReportsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Background="#E8F1FF" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="В процессе" FontSize="12" Foreground="#2457A6"/>
                                <TextBlock Text="{Binding InProgressAppointmentsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Background="#DFF5E1" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Завершено" FontSize="12" Foreground="#1E7E34"/>
                                <TextBlock Text="{Binding CompletedAppointmentsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="2" Background="#FDE2E2" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Неявки" FontSize="12" Foreground="#B00020"/>
                                <TextBlock Text="{Binding NoShowAppointmentsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                          </Grid>
                        </StackPanel>
                      </Border>

                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>
          </Border>

          <Border Grid.Column="1"
                  Background="#FFFFFF"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12">

            <StackPanel Spacing="8">
              <TextBlock Text="Статистика по шаблонам"
                         FontSize="18"
                         FontWeight="Bold"/>

              <ScrollViewer MaxHeight="420"
                            VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding TemplateRows}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="stats:TemplateStatisticsDto">

                      <Border Background="#F7F8FA"
                              BorderBrush="#DDDDDD"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="10"
                              Margin="0,0,0,8">

                        <StackPanel Spacing="8">

                          <TextBlock Text="{Binding TemplateName}"
                                     FontWeight="Bold"
                                     FontSize="15"
                                     TextWrapping="Wrap"/>

                          <Grid ColumnDefinitions="*,*,*,*"
                                RowDefinitions="Auto,Auto"
                                ColumnSpacing="8"
                                RowSpacing="8">

                            <Border Grid.Row="0" Grid.Column="0" Background="#E8F1FF" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Записей" FontSize="12" Foreground="#2457A6"/>
                                <TextBlock Text="{Binding AppointmentsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Background="#DFF5E1" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Принято" FontSize="12" Foreground="#1E7E34"/>
                                <TextBlock Text="{Binding AcceptedAppointmentsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" Background="#F3E8FF" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Пациентов" FontSize="12" Foreground="#6F2DA8"/>
                                <TextBlock Text="{Binding UniqueAcceptedPatientsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="3" Background="#FFF3CD" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Отчётов" FontSize="12" Foreground="#7A5B00"/>
                                <TextBlock Text="{Binding ReportsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Background="#E8F1FF" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="В процессе" FontSize="12" Foreground="#2457A6"/>
                                <TextBlock Text="{Binding InProgressAppointmentsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Background="#DFF5E1" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Завершено" FontSize="12" Foreground="#1E7E34"/>
                                <TextBlock Text="{Binding CompletedAppointmentsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="2" Background="#FDE2E2" CornerRadius="8" Padding="8">
                              <StackPanel>
                                <TextBlock Text="Неявки" FontSize="12" Foreground="#B00020"/>
                                <TextBlock Text="{Binding NoShowAppointmentsCount}" FontSize="20" FontWeight="Bold"/>
                              </StackPanel>
                            </Border>

                          </Grid>
                        </StackPanel>
                      </Border>

                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>
          </Border>
        </Grid>

        <Grid ColumnDefinitions="*,*"
              ColumnSpacing="12">

          <Border Grid.Column="0"
                  Background="#FFFFFF"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12">

            <StackPanel Spacing="8">
              <TextBlock Text="Статусы записей"
                         FontSize="18"
                         FontWeight="Bold"/>

              <ItemsControl ItemsSource="{Binding AppointmentStatusRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:AppointmentStatusStatisticsViewItem">
                    <Border Background="#F7F8FA"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8">

                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding StatusText}"
                                   FontWeight="Bold"/>

                        <Border Grid.Column="1"
                                Background="#EEF2F7"
                                CornerRadius="10"
                                Padding="10,4">
                          <TextBlock Text="{Binding Count}"
                                     FontWeight="Bold"/>
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Grid.Column="1"
                  Background="#FFFFFF"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12">

            <StackPanel Spacing="8">
              <TextBlock Text="Статусы отчётов"
                         FontSize="18"
                         FontWeight="Bold"/>

              <ItemsControl ItemsSource="{Binding ReportStatusRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ReportStatusStatisticsViewItem">
                    <Border Background="#F7F8FA"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8">

                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding StatusText}"
                                   FontWeight="Bold"/>

                        <Border Grid.Column="1"
                                Background="#EEF2F7"
                                CornerRadius="10"
                                Padding="10,4">
                          <TextBlock Text="{Binding Count}"
                                     FontWeight="Bold"/>
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </Grid>

      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="3"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,10,0,0">

      <DockPanel>
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="{Binding SuccessMessage}"
                     Foreground="Green"/>
          <TextBlock Text="{Binding ErrorMessage}"
                     Foreground="Red"/>
        </StackPanel>

        <ProgressBar DockPanel.Dock="Right"
                     Width="180"
                     Height="14"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsBusy}"/>
      </DockPanel>
    </Border>

  </Grid>
</UserControl>
