<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UltrasoundAssistant.DoctorClient.ViewModels.Patient"
             x:Class="UltrasoundAssistant.DoctorClient.Views.Patient.PatientsView"
             x:DataType="vm:PatientsViewModel"
             x:Name="Root"
             AttachedToVisualTree="UserControl_OnAttachedToVisualTree">

  <Grid Margin="14"
        RowDefinitions="Auto,*,Auto"
        ColumnDefinitions="3*,2*">

    <Border Grid.Row="0"
            Grid.Column="0"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,10,10">

      <StackPanel Spacing="10">

        <DockPanel>
          <Button Content="← Назад"
                  Command="{Binding GoBackCommand}"
                  DockPanel.Dock="Left"/>

          <TextBlock Text="Список пациентов"
                     FontSize="20"
                     FontWeight="Bold"
                     Margin="12,0,0,0"
                     VerticalAlignment="Center"/>
        </DockPanel>

        <StackPanel Orientation="Horizontal"
                    Spacing="8">

          <TextBox Width="320"
                   Watermark="Поиск по ФИО"
                   Text="{Binding SearchFullName, UpdateSourceTrigger=PropertyChanged}"/>

          <Button Content="Найти"
                  Command="{Binding SearchPatientsCommand}"/>

          <Button Content="Обновить"
                  Command="{Binding LoadPatientsCommand}"/>

          <Button Content="Сбросить"
                  Command="{Binding ClearFiltersCommand}"/>
        </StackPanel>

        <Expander Header="Дополнительные параметры"
                  IsExpanded="{Binding AreAdditionalFiltersVisible}">

          <Grid ColumnDefinitions="*,*,*"
                RowDefinitions="Auto,Auto"
                Margin="0,10,0,0"
                ColumnSpacing="10"
                RowSpacing="8">

            <StackPanel Grid.Row="0" Grid.Column="0">
              <TextBlock Text="Дата рождения"/>
              <DatePicker SelectedDate="{Binding FilterBirthDate}"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1">
              <TextBlock Text="Телефон"/>
              <TextBox Text="{Binding FilterPhoneNumber, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="2">
              <TextBlock Text="Тип документа"/>
              <ComboBox ItemsSource="{Binding DocumentTypeOptions}"
                        SelectedItem="{Binding SelectedDocumentTypeText}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0">
              <TextBlock Text="Серия документа"/>
              <TextBox Text="{Binding FilterDocumentSeries, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1">
              <TextBlock Text="Номер документа"/>
              <TextBox Text="{Binding FilterDocumentNumber, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="2">
              <TextBlock Text="Удалённые пациенты"/>
              <ComboBox ItemsSource="{Binding DeletedOptions}"
                        SelectedItem="{Binding SelectedDeletedOption}"/>
            </StackPanel>

          </Grid>
        </Expander>

      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1"
                  Grid.Column="0"
                  Margin="0,0,10,0"
                  VerticalScrollBarVisibility="Auto">

      <ItemsControl ItemsSource="{Binding Patients}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:PatientAdminListItem">

            <Border Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,0,10">

              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">

                <StackPanel Grid.Column="0"
                            Spacing="8">

                  <StackPanel Orientation="Horizontal"
                              Spacing="8">

                    <TextBlock Text="{Binding FullName}"
                               FontSize="17"
                               FontWeight="Bold"
                               TextWrapping="Wrap"/>

                    <Border Background="{Binding StatusBackground}"
                            CornerRadius="10"
                            Padding="8,3"
                            VerticalAlignment="Center">

                      <TextBlock Text="{Binding StatusText}"
                                 Foreground="{Binding StatusForeground}"
                                 FontSize="12"
                                 FontWeight="Bold"/>
                    </Border>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*,*"
                        ColumnSpacing="10">

                    <Border Grid.Column="0"
                            Background="#E8F1FF"
                            CornerRadius="8"
                            Padding="10">

                      <StackPanel>
                        <TextBlock Text="Дата рождения"
                                   Foreground="#2457A6"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding BirthDateText}"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding AgeText}"
                                   Foreground="#666"
                                   FontSize="12"/>
                      </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#F3E8FF"
                            CornerRadius="8"
                            Padding="10">

                      <StackPanel>
                        <TextBlock Text="Пол"
                                   Foreground="#6F2DA8"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding GenderText}"
                                   FontWeight="Bold"/>
                      </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#DFF5E1"
                            CornerRadius="8"
                            Padding="10">

                      <StackPanel>
                        <TextBlock Text="Телефон"
                                   Foreground="#1E7E34"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding PhoneText}"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                    </Border>
                  </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="8"
                            VerticalAlignment="Center">

                  <Button Content="Изменить"
                          Command="{Binding #Root.DataContext.EditPatientCommand}"
                          CommandParameter="{Binding}"
                          Padding="12,6"/>

                  <Button Content="Удалить"
                          Background="#E74C3C"
                          Foreground="White"
                          Command="{Binding #Root.DataContext.DeletePatientCommand}"
                          CommandParameter="{Binding}"
                          Padding="12,6"/>
                </StackPanel>
              </Grid>
            </Border>

          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <StackPanel Grid.Row="2"
                Grid.Column="0"
                Orientation="Horizontal"
                Spacing="10"
                Margin="0,10,10,0">

      <Button Content="Добавить пациента"
              Padding="14,7"
              Command="{Binding AddPatientCommand}"/>

      <TextBlock Text="{Binding ErrorMessage}"
                 Foreground="Red"
                 VerticalAlignment="Center"/>
    </StackPanel>

    <Border Grid.Row="0"
            Grid.RowSpan="3"
            Grid.Column="1"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            IsVisible="{Binding IsEditPanelVisible}">

      <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Spacing="10">

          <TextBlock Text="{Binding EditPanelTitle}"
                     FontWeight="Bold"
                     FontSize="18"/>

          <TextBlock Text="ФИО"/>
          <TextBox Text="{Binding EditFullName, UpdateSourceTrigger=PropertyChanged}"/>

          <TextBlock Text="Дата рождения"/>
          <DatePicker SelectedDate="{Binding EditBirthDate}"/>

          <TextBlock Text="Пол"/>
          <ComboBox ItemsSource="{Binding Genders}"
                    SelectedItem="{Binding EditSelectedGender}"/>

          <TextBlock Text="Телефон"/>
          <TextBox Text="{Binding EditPhoneNumber, UpdateSourceTrigger=PropertyChanged}"/>

          <TextBlock Text="Email"/>
          <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"/>

          <Border Background="#FFFFFF"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10"
                  Margin="0,8,0,0">

            <StackPanel Spacing="10">

              <DockPanel>
                <TextBlock Text="Документы пациента"
                           FontSize="16"
                           FontWeight="Bold"
                           DockPanel.Dock="Left"/>

                <Button Content="Добавить документ"
                        Command="{Binding AddDocumentCommand}"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right"/>
              </DockPanel>

              <ItemsControl ItemsSource="{Binding EditableDocuments}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:EditablePatientDocumentItem">

                    <Border Background="#F7F8FA"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,10">

                      <StackPanel Spacing="8">

                        <DockPanel>
                          <TextBlock Text="Документ"
                                     FontWeight="Bold"
                                     DockPanel.Dock="Left"/>

                          <Button Content="Удалить"
                                  Background="#E74C3C"
                                  Foreground="White"
                                  Command="{Binding #Root.DataContext.RemoveDocumentCommand}"
                                  CommandParameter="{Binding}"
                                  DockPanel.Dock="Right"/>
                        </DockPanel>

                        <TextBlock Text="Тип документа"/>
                        <ComboBox ItemsSource="{Binding #Root.DataContext.DocumentTypeOptions}"
                                  SelectedItem="{Binding DocumentTypeText}"/>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8">

                          <StackPanel Grid.Column="0">
                            <TextBlock Text="Серия"/>
                            <TextBox Text="{Binding Series, UpdateSourceTrigger=PropertyChanged}"/>
                          </StackPanel>

                          <StackPanel Grid.Column="1">
                            <TextBlock Text="Номер"/>
                            <TextBox Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}"/>
                          </StackPanel>
                        </Grid>

                        <TextBlock Text="Кем выдан"/>
                        <TextBox Text="{Binding IssuedBy, UpdateSourceTrigger=PropertyChanged}"/>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8">

                          <StackPanel Grid.Column="0">
                            <TextBlock Text="Дата выдачи"/>
                            <DatePicker SelectedDate="{Binding IssueDate}"/>
                          </StackPanel>

                          <StackPanel Grid.Column="1">
                            <TextBlock Text="Код подразделения"/>
                            <TextBox Text="{Binding DepartmentCode, UpdateSourceTrigger=PropertyChanged}"/>
                          </StackPanel>
                        </Grid>

                        <TextBlock Text="Организация"/>
                        <TextBox Text="{Binding Organization, UpdateSourceTrigger=PropertyChanged}"/>

                      </StackPanel>
                    </Border>

                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Text="Если документов нет, можно оставить список пустым."
                         Foreground="#666"
                         TextWrapping="Wrap"/>

            </StackPanel>
          </Border>

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="10"
                      Margin="0,16,0,0">

            <Button Content="Сохранить"
                    Command="{Binding SavePatientCommand}"/>

            <Button Content="Отмена"
                    Command="{Binding CancelEditCommand}"/>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </Border>

  </Grid>
</UserControl>
