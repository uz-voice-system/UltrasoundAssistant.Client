<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UltrasoundAssistant.DoctorClient.ViewModels.Appointment"
             xmlns:patients="using:UltrasoundAssistant.DoctorClient.Models.Reads.Patients.Search"
             xmlns:users="using:UltrasoundAssistant.DoctorClient.Models.Reads.Users.Search"
             xmlns:templates="using:UltrasoundAssistant.DoctorClient.Models.Reads.Templates.Search"
             x:Class="UltrasoundAssistant.DoctorClient.Views.Appointment.AppointmentRegistrationView"
             x:DataType="vm:AppointmentRegistrationViewModel"
             x:Name="Root"
             AttachedToVisualTree="UserControl_OnAttachedToVisualTree">

  <Grid Margin="14"
        RowDefinitions="Auto,*,Auto"
        ColumnDefinitions="420,*">

    <!-- Заголовок -->
    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,10">

      <DockPanel>
        <Button Content="← Назад"
                Command="{Binding GoBackCommand}"
                DockPanel.Dock="Left"/>

        <StackPanel Margin="12,0,0,0">
          <TextBlock Text="Запись пациента на приём"
                     FontSize="20"
                     FontWeight="Bold"/>

          <TextBlock Text="Выберите пациента, врача, шаблон и свободное время"
                     Foreground="#666"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Левая панель: новая запись -->
    <Border Grid.Row="1"
            Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,10,0">

      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">

          <TextBlock Text="Новая запись"
                     FontSize="18"
                     FontWeight="Bold"/>

          <!-- Пациент -->
          <StackPanel Spacing="6">
            <TextBlock Text="Пациент"
                       FontWeight="SemiBold"/>

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="6">
              <TextBox Grid.Column="0"
                       Watermark="Поиск пациента"
                       Text="{Binding PatientSearchText, UpdateSourceTrigger=PropertyChanged}"/>

              <Button Grid.Column="1"
                      Content="Найти"
                      Command="{Binding SearchPatientsCommand}"/>
            </Grid>

            <ComboBox ItemsSource="{Binding Patients}"
                      SelectedItem="{Binding SelectedPatient}"
                      PlaceholderText="Выберите пациента"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="patients:PatientSummaryDto">
                  <StackPanel>
                    <TextBlock Text="{Binding FullName}"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding PhoneNumber}"
                               Foreground="#777"
                               FontSize="12"/>
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <!-- Врач -->
          <StackPanel Spacing="6">
            <TextBlock Text="Врач"
                       FontWeight="SemiBold"/>

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="6">
              <TextBox Grid.Column="0"
                       Watermark="Поиск врача"
                       Text="{Binding DoctorSearchText, UpdateSourceTrigger=PropertyChanged}"/>

              <Button Grid.Column="1"
                      Content="Найти"
                      Command="{Binding SearchDoctorsCommand}"/>
            </Grid>

            <ComboBox ItemsSource="{Binding Doctors}"
                      SelectedItem="{Binding SelectedDoctor}"
                      PlaceholderText="Выберите врача"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="users:UserSummaryDto">
                  <StackPanel>
                    <TextBlock Text="{Binding FullName}"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding Specialization}"
                               Foreground="#777"
                               FontSize="12"/>

                    <TextBlock Text="{Binding Cabinet, StringFormat='Кабинет: {0}'}"
                               Foreground="#777"
                               FontSize="12"/>
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <!-- Шаблон -->
          <StackPanel Spacing="6">
            <TextBlock Text="Шаблон исследования"
                       FontWeight="SemiBold"/>

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="6">
              <TextBox Grid.Column="0"
                       Watermark="Поиск шаблона"
                       Text="{Binding TemplateSearchText, UpdateSourceTrigger=PropertyChanged}"/>

              <Button Grid.Column="1"
                      Content="Найти"
                      Command="{Binding SearchTemplatesCommand}"/>
            </Grid>

            <ComboBox ItemsSource="{Binding Templates}"
                      SelectedItem="{Binding SelectedTemplate}"
                      PlaceholderText="Выберите шаблон"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="templates:TemplateSummaryDto">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding DefaultAppointmentDurationMinutes, StringFormat='Длительность: {0} мин.'}"
                               Foreground="#777"
                               FontSize="12"/>
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <!-- Дата и время -->

        <StackPanel Spacing="6">
            <TextBlock Text="Дата" FontWeight="SemiBold"/>

            <DatePicker SelectedDate="{Binding AppointmentDate}"
                        Width="300"
                        HorizontalAlignment="Stretch"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="6">
            <TextBlock Text="Время" FontWeight="SemiBold"/>

        <TimePicker SelectedTime="{Binding AppointmentTime}"
                    Width="300"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>

          <!-- Длительность -->
          <StackPanel Spacing="6">
            <TextBlock Text="Длительность, минут"
                       FontWeight="SemiBold"/>

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <NumericUpDown Grid.Column="0"
                             Minimum="5"
                             Maximum="240"
                             Increment="5"
                             Value="{Binding DurationMinutes}"/>

              <Button Grid.Column="1"
                      Content="Сбросить"
                      Command="{Binding ResetDurationFromTemplateCommand}"/>
            </Grid>
          </StackPanel>

          <!-- Комментарий -->
          <StackPanel Spacing="6">
            <TextBlock Text="Комментарий"
                       FontWeight="SemiBold"/>

            <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     MinHeight="70"
                     Watermark="Комментарий к записи, если нужен"/>
          </StackPanel>

          <Grid ColumnDefinitions="*,*"
                ColumnSpacing="8"
                Margin="0,6,0,0">

            <Button Grid.Column="0"
                    Content="Записать пациента"
                    Command="{Binding CreateAppointmentCommand}"
                    Padding="14,8"
                    HorizontalAlignment="Stretch"/>

            <Button Grid.Column="1"
                    Content="Сбросить выбор"
                    Command="{Binding ResetNewAppointmentCommand}"
                    Padding="14,8"
                    HorizontalAlignment="Stretch"/>
          </Grid>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Правая область: расписание врача -->
    <Border Grid.Row="1"
            Grid.Column="1"
            Background="#FFFFFF"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            IsVisible="{Binding IsDoctorScheduleVisible}">

      <Grid RowDefinitions="Auto,*">

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,10">

          <StackPanel DockPanel.Dock="Left">
            <TextBlock Text="Расписание врача"
                       FontSize="18"
                       FontWeight="Bold"/>

            <TextBlock Text="{Binding SelectedDoctor.FullName}"
                       Foreground="#666"/>
          </StackPanel>

          <Button Content="Вернуться к списку записей"
                  Command="{Binding ResetDoctorScheduleViewCommand}"
                  DockPanel.Dock="Right"
                  Padding="12,6"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

          <ItemsControl ItemsSource="{Binding DoctorScheduleDays}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:DoctorDayScheduleViewItem">

                <Border Background="{Binding CardBackground}"
                        BorderBrush="{Binding CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,10">

                  <StackPanel Spacing="8">

                    <DockPanel>
                      <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{Binding DayName}"
                                   FontWeight="Bold"
                                   FontSize="16"/>

                        <TextBlock Text="{Binding DateText}"
                                   Foreground="#666"/>
                      </StackPanel>

                      <Border DockPanel.Dock="Right"
                              Background="{Binding StatusBackground}"
                              CornerRadius="10"
                              Padding="10,4">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{Binding StatusForeground}"
                                   FontWeight="SemiBold"/>
                      </Border>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding Slots}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>

                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:DoctorTimeSlotViewItem">

                          <Button Command="{Binding #Root.DataContext.SelectTimeSlotCommand}"
                                  CommandParameter="{Binding}"
                                  IsEnabled="{Binding CanSelect}"
                                  Padding="0"
                                  Margin="0,0,8,8"
                                  Background="Transparent"
                                  BorderThickness="0">

                            <Border Background="{Binding Background}"
                                    BorderBrush="{Binding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8"
                                    MinWidth="175">

                              <StackPanel>
                                <TextBlock Text="{Binding TimeText}"
                                           FontWeight="Bold"
                                           TextWrapping="NoWrap"/>

                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{Binding Foreground}"
                                           FontSize="12"/>

                                <TextBlock Text="{Binding PatientText}"
                                           Foreground="#666"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                              </StackPanel>
                            </Border>
                          </Button>

                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                  </StackPanel>
                </Border>

              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Правая область: существующие записи -->
    <Grid Grid.Row="1"
          Grid.Column="1"
          RowDefinitions="Auto,*"
          IsVisible="{Binding IsAppointmentsPanelVisible}">

      <Border Grid.Row="0"
              Background="#F7F8FA"
              BorderBrush="#DDDDDD"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12"
              Margin="0,0,0,10">

        <StackPanel Spacing="10">

          <TextBlock Text="Существующие записи"
                     FontSize="18"
                     FontWeight="Bold"/>

          <Grid ColumnDefinitions="300,300,Auto,Auto"
                ColumnSpacing="8">

            <StackPanel Grid.Column="0">
              <TextBlock Text="Дата с"/>
                 <DatePicker SelectedDate="{Binding FilterFromDate}"
                             Width="300"
                             HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
              <TextBlock Text="Дата по"/>
                  <DatePicker SelectedDate="{Binding FilterToDate}"
                              Width="300"
                              HorizontalAlignment="Stretch"/>
            </StackPanel>

            <Button Grid.Column="2"
                    Content="Найти"
                    Command="{Binding SearchAppointmentsCommand}"
                    VerticalAlignment="Bottom"
                    Padding="12,6"/>

            <Button Grid.Column="3"
                    Content="Сбросить"
                    Command="{Binding ClearAppointmentFiltersCommand}"
                    VerticalAlignment="Bottom"
                    Padding="12,6"/>
          </Grid>

          <Expander Header="Дополнительные параметры"
                    IsExpanded="{Binding AreAdditionalFiltersVisible}">

            <Grid ColumnDefinitions="*,*,*,Auto"
                  ColumnSpacing="10"
                  Margin="0,10,0,0">

              <StackPanel Grid.Column="0">
                <TextBlock Text="Статус"/>
                <ComboBox ItemsSource="{Binding StatusFilterOptions}"
                          SelectedItem="{Binding FilterStatusText}"
                          HorizontalAlignment="Stretch"/>
              </StackPanel>

              <StackPanel Grid.Column="1">
                <TextBlock Text="Врач"/>
                <ComboBox ItemsSource="{Binding Doctors}"
                          SelectedItem="{Binding FilterDoctor}"
                          PlaceholderText="Все врачи"
                          HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="users:UserSummaryDto">
                      <TextBlock Text="{Binding FullName}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="Шаблон"/>
                <ComboBox ItemsSource="{Binding Templates}"
                          SelectedItem="{Binding FilterTemplate}"
                          PlaceholderText="Все шаблоны"
                          HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="templates:TemplateSummaryDto">
                      <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <CheckBox Grid.Column="3"
                        Content="Показывать удалённые"
                        IsChecked="{Binding IncludeDeleted}"
                        VerticalAlignment="Bottom"/>
            </Grid>
          </Expander>
        </StackPanel>
      </Border>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto">

        <ItemsControl ItemsSource="{Binding Appointments}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:AppointmentCardViewItem">

              <Border Background="{Binding CardBackground}"
                      BorderBrush="{Binding CardBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="12"
                      Margin="0,0,0,10">

                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="8">

                  <StackPanel Grid.Row="0"
                              Grid.Column="0"
                              Spacing="4">

                    <TextBlock Text="{Binding PatientFullName}"
                               FontSize="16"
                               FontWeight="Bold"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding TemplateName}"
                               Foreground="#666"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding DoctorFullName}"
                               Foreground="#666"
                               TextWrapping="Wrap"/>
                  </StackPanel>

                  <StackPanel Grid.Row="0"
                              Grid.Column="1"
                              HorizontalAlignment="Right"
                              Spacing="6">

                    <Border Background="{Binding StatusBackground}"
                            CornerRadius="10"
                            Padding="10,4"
                            HorizontalAlignment="Right">
                      <TextBlock Text="{Binding StatusText}"
                                 Foreground="{Binding StatusForeground}"
                                 FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock Text="{Binding ReportText}"
                               Foreground="#666"
                               HorizontalAlignment="Right"/>
                  </StackPanel>

                  <Grid Grid.Row="1"
                        Grid.ColumnSpan="2"
                        ColumnDefinitions="*,Auto"
                        ColumnSpacing="10">

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="12">

                      <TextBlock Text="{Binding DateText}"
                                 FontWeight="SemiBold"/>

                      <TextBlock Text="{Binding TimeText}"
                                 FontWeight="SemiBold"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Отменить запись"
                            Command="{Binding #Root.DataContext.CancelAppointmentCommand}"
                            CommandParameter="{Binding}"
                            IsVisible="{Binding CanCancel}"
                            Background="#E74C3C"
                            Foreground="White"
                            Padding="10,5"/>
                  </Grid>
                </Grid>
              </Border>

            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

    <!-- Нижняя панель -->
    <Border Grid.Row="2"
            Grid.ColumnSpan="2"
            Background="#F7F8FA"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,10,0,0">

      <DockPanel>
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="{Binding SuccessMessage}"
                     Foreground="Green"/>

          <TextBlock Text="{Binding ErrorMessage}"
                     Foreground="Red"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <ProgressBar DockPanel.Dock="Right"
                     Width="180"
                     Height="14"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsBusy}"/>
      </DockPanel>
    </Border>

  </Grid>
</UserControl>
