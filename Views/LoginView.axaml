<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UltrasoundAssistant.DoctorClient.ViewModels"
             x:Class="UltrasoundAssistant.DoctorClient.Views.LoginView"
             x:DataType="vm:LoginViewModel">

  <Grid>
    <Border Width="420"
            Padding="24"
            CornerRadius="12"
            Background="#F3F4F6"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      
      <StackPanel Spacing="12">
        <TextBlock Text="Вход в систему"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" />

        <TextBlock Text="Логин" />
        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                 Watermark="Введите логин" />

        <TextBlock Text="Пароль" />
        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                 PasswordChar="*"
                 Watermark="Введите пароль" />

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   IsVisible="{Binding ErrorMessage}" />

        <Button Content="Войти"
                Command="{Binding SignInCommand}"
                IsEnabled="{Binding !IsBusy}"
                Height="40"
                Margin="0,8,0,0" />

        <TextBlock Text="Выполняется вход..."
                   HorizontalAlignment="Center"
                   IsVisible="{Binding IsBusy}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>